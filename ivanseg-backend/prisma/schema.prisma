generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id               String            @id @default(uuid())
  nombreCompleto   String            @map("nombre_completo")
  telefono         String
  cedula           String?
  correo           String?
  createdAt        DateTime          @default(now()) @map("created_at")
  establecimientos Establecimiento[]

  @@index([telefono])
  @@index([nombreCompleto])
  @@map("clientes")
}

model Establecimiento {
  id                    String                 @id @default(uuid())
  clienteId             String                 @map("cliente_id")
  latitud               Float
  longitud              Float
  direccionTexto        String?                @map("direccion_texto")
  observaciones         String?
  createdAt             DateTime               @default(now()) @map("created_at")
  razonSocial           String                 @map("razon_social")
  cliente               Cliente                @relation(fields: [clienteId], references: [id])
  extintores            Extintor[]
  mantenimientosGeneral MantenimientoGeneral[]

  @@index([clienteId])
  @@index([latitud, longitud])
  @@index([razonSocial])
  @@map("establecimientos")
}

model Extintor {
  id                String          @id @default(uuid())
  establecimientoId String          @map("establecimiento_id")
  tipo              String
  pesoKg            Float           @map("peso_kg")
  numeroSerie       String?         @map("numero_serie")
  ubicacionInterna  String?         @map("ubicacion_interna")
  createdAt         DateTime        @default(now()) @map("created_at")
  establecimiento   Establecimiento @relation(fields: [establecimientoId], references: [id])
  mantenimientos    Mantenimiento[]

  @@index([establecimientoId])
  @@index([numeroSerie])
  @@index([tipo])
  @@map("extintores")
}

model Mantenimiento {
  id                        String              @id @default(uuid())
  extintorId                String              @map("extintor_id")
  fechaBaseMantenimiento    DateTime            @map("fecha_base_mantenimiento")
  fechaUltimoMantenimiento  DateTime?           @map("fecha_ultimo_mantenimiento")
  fechaProximoMantenimiento DateTime            @map("fecha_proximo_mantenimiento")
  estado                    EstadoMantenimiento @default(pendiente)
  observaciones             String?
  createdAt                 DateTime            @default(now()) @map("created_at")
  extintor                  Extintor            @relation(fields: [extintorId], references: [id])

  @@index([extintorId])
  @@index([fechaProximoMantenimiento])
  @@index([estado])
  @@map("mantenimientos")
}

model MantenimientoGeneral {
  id                        String              @id @default(uuid())
  establecimientoId         String              @map("establecimiento_id")
  fechaProximoMantenimiento DateTime            @map("fecha_proximo_mantenimiento") @db.Date
  estado                    EstadoMantenimiento @default(pendiente)
  competenciaActual         String?             @map("competencia_actual")
  observaciones             String?
  createdAt                 DateTime            @default(now()) @map("created_at")
  establecimiento           Establecimiento     @relation(fields: [establecimientoId], references: [id])

  @@index([establecimientoId])
  @@index([fechaProximoMantenimiento])
  @@index([estado])
  @@map("mantenimientos_generales")
}

enum EstadoMantenimiento {
  pendiente
  completado
  vencido
}

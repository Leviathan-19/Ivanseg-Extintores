generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id               String            @id @default(uuid())
  nombreCompleto   String            @map("nombre_completo")
  telefono         String
  cedula           String?
  correo           String?
  createdAt        DateTime          @default(now()) @map("created_at")
  establecimientos Establecimiento[]

  @@index([telefono])
  @@index([nombreCompleto])
  @@map("clientes")
}

model Establecimiento {
  id                    String                 @id @default(uuid())
  clienteId             String                 @map("cliente_id")
  latitud               Float
  longitud              Float
  direccionTexto        String?                @map("direccion_texto")
  observaciones         String?
  createdAt             DateTime               @default(now()) @map("created_at")
  razonSocial           String                 @map("razon_social")
  cliente               Cliente                @relation(fields: [clienteId], references: [id])
  extintores            Extintor[]
  mantenimientosGeneral MantenimientoGeneral[]

  @@index([clienteId])
  @@index([latitud, longitud])
  @@index([razonSocial])
  @@map("establecimientos")
}

model Extintor {
  id                String          @id @default(uuid())
  establecimientoId String          @map("establecimiento_id")
  tipo              String
  pesoKg            Float           @map("peso_kg")
  numeroSerie       String?         @map("numero_serie")
  ubicacionInterna  String?         @map("ubicacion_interna")
  createdAt         DateTime        @default(now()) @map("created_at")
  establecimiento   Establecimiento @relation(fields: [establecimientoId], references: [id])
  mantenimientos    Mantenimiento[]

  @@index([establecimientoId])
  @@index([numeroSerie])
  @@index([tipo])
  @@map("extintores")
}

model Mantenimiento {
  id                        String              @id @default(uuid())
  extintorId                String              @map("extintor_id")
  fechaBaseMantenimiento    DateTime            @map("fecha_base_mantenimiento")
  fechaUltimoMantenimiento  DateTime?           @map("fecha_ultimo_mantenimiento")
  fechaProximoMantenimiento DateTime            @map("fecha_proximo_mantenimiento")
  estado                    EstadoMantenimiento @default(pendiente)
  observaciones             String?
  createdAt                 DateTime            @default(now()) @map("created_at")
  extintor                  Extintor            @relation(fields: [extintorId], references: [id])

  @@index([extintorId])
  @@index([fechaProximoMantenimiento])
  @@index([estado])
  @@map("mantenimientos")
}

model MantenimientoGeneral {
  id                        String              @id @default(uuid())
  establecimientoId         String              @map("establecimiento_id")
  fechaProximoMantenimiento DateTime            @map("fecha_proximo_mantenimiento") @db.Date
  estado                    EstadoMantenimiento @default(pendiente)
  competenciaActual         String?             @map("competencia_actual")
  observaciones             String?
  createdAt                 DateTime            @default(now()) @map("created_at")
  establecimiento           Establecimiento     @relation(fields: [establecimientoId], references: [id])

  @@index([establecimientoId])
  @@index([fechaProximoMantenimiento])
  @@index([estado])
  @@map("mantenimientos_generales")
}

enum EstadoMantenimiento {
  pendiente
  completado
  vencido
}

model Provincia {
  id        String   @id @default(uuid())
  nombre    String   @unique

  cantones  Canton[]

  @@map("provincias")
}

model Canton {
  id           String      @id @default(uuid())
  nombre       String
  provinciaId  String      @map("provincia_id")

  provincia    Provincia   @relation(fields: [provinciaId], references: [id])
  parroquias   Parroquia[]

  @@unique([nombre, provinciaId])
  @@index([provinciaId])
  @@map("cantones")
}

model Parroquia {
  id         String     @id @default(uuid())
  nombre     String
  cantonId   String     @map("canton_id")

  canton     Canton     @relation(fields: [cantonId], references: [id])
  barrios    Barrio[]

  @@unique([nombre, cantonId])
  @@index([cantonId])
  @@map("parroquias")
}

model Barrio {
  id           String      @id @default(uuid())
  nombre       String
  parroquiaId  String      @map("parroquia_id")

  parroquia    Parroquia   @relation(fields: [parroquiaId], references: [id])
  visitas  Visita[]

  @@unique([nombre, parroquiaId])
  @@index([parroquiaId])
  @@map("barrios")
}

model Visita {
  id              String    @id @default(uuid())
  barrioId        String    @map("barrio_id")
  nombreCliente   String?   @map("nombre_cliente")
  razonSocial     String    @map("razon_social")
  telefono        String?
  correo          String?
  callePrincipal  String     @map("calle_principal")
  calleSecundaria String?    @map("calle_secundaria")
  numeracion      String?
  latitud         Float?
  longitud        Float?
  estadoVisita    String?    @default("pendiente") @map("estado_visita")
  proximaVisita   DateTime  @map("proxima_visita") @db.Date
  fechaVisita     DateTime  @default(now()) @map("fecha_visita")

  barrio          Barrio     @relation(fields: [barrioId], references: [id])

  @@index([estadoVisita])
  @@index([proximaVisita])
  @@index([barrioId])
  @@index([latitud, longitud])
  @@map("visitas")
}